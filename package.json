{
  "name": "w2ui",
  "version": "2.0.0",
  "title": "W2UI: New JavaScript UI Library",
  "description": "JavaScript UI library for development of data-driven web applications. Includes layout, grid, toolbar, sidebar, tabs, forms, fields, popup, overlay",
  "license": "MIT",
  "repository": "https://github.com/vitmalina/w2ui",
  "dependencies": {
    "jquery": ">=3.5"
  },
  "main": "dist/w2ui.js",
  "module": "dist/w2ui.es6.js",
  "types": "dist/w2ui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/w2ui.d.ts",
      "import": "./dist/w2ui.es6.js",
      "require": "./dist/w2ui.js"
    },
    "./css": "./dist/w2ui.css",
    "./dark": "./dist/w2ui-dark.css"
  },
  "style": "dist/w2ui.css",
  "scripts": {
    "start": "run-script-os",
    "start:win32": "start http://localhost:3500 & python -m http.server 3500",
    "start:nix": "open http://localhost:3500; python3 -m http.server 3500",
    "lint": "eslint src demos --ext .js,.ts",
    "typecheck": "tsc --noEmit",
    "build:css": "gulp less && gulp icons",
    "build:js": "tsup --config tsup.config.ts && node scripts/wrap-legacy.mjs",
    "build": "pnpm build:css && pnpm build:js",
    "smoke": "playwright test",
    "smoke:update": "playwright test --update-snapshots",
    "verify": "pnpm lint && pnpm typecheck && pnpm smoke",
    "test": "pnpm lint && pnpm typecheck",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@babel/core": "^7.19.3",
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "del": "^6.0.0",
    "eslint": "^8.25.0",
    "eslint-plugin-align-assignments": "^1.1.2",
    "gulp": "^4.0.2",
    "gulp-babel": "^8.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-header": "^2.0.9",
    "gulp-iconfont": "^11.0.0",
    "gulp-less": "^4.0.1",
    "gulp-rename": "^2.0.0",
    "gulp-replace": "^1.0.0",
    "gulp-uglify": "^3.0.2",
    "run-script-os": "^1.1.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
