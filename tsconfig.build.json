{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "allowJs": false,
        "checkJs": false,
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noImplicitOverride": true,
        "noPropertyAccessFromIndexSignature": true,
        "stripInternal": true,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": false,
        "noEmit": false
    }
}
